# Copy to data/runtime.env on each server:
#   cp data/runtime.env.example data/runtime.env
#   openssl rand -hex 32  # set DASHBOARD_TOKEN

REDIS_ADDR=redis:6379
POLICY_PATH=/data/lab-policy.yaml
PHASES_PATH=/configs/phases.yaml
COMBOS_PATH=/configs/combos.yaml
# Listen on all interfaces (required for public IP / EC2 access)
DASHBOARD_ADDR=0.0.0.0:8089
DASHBOARD_TOKEN=change-me-run-openssl-rand-hex-32
TARGET_URL=http://victim:80